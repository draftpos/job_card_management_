                                    <th name="th_uom" class="text-start" style="border: none; padding: 16px 14px; font-size: 14px; font-weight: 700; color: #1a1a2e; letter-spacing: 0.6px; text-transform: uppercase; width: 15%;">UOM</th>
                                </tr>
                            </thead>
                            <tbody class="pick_slip_tbody">
                                <t t-foreach="doc.job_card_lines" t-as="line">
