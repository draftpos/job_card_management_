                                    <span t-field="doc.customer_id.name"/><br/>
                                    <t t-if="doc.customer_id.street"><span t-field="doc.customer_id.street"/><br/></t>
                                    <t t-if="doc.customer_id.city"><span t-field="doc.customer_id.city"/><t t-if="doc.customer_id.country">, <span t-field="doc.customer_id.country"/></t><br/></t>
                                    <t t-if="doc.customer_id.phone">Phone: <span t-field="doc.customer_id.phone"/><br/></t>
                                    <t t-if="doc.customer_id.email">Email: <span t-field="doc.customer_id.email"/></t>
                                </div>
                            </div>
