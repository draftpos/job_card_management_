<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Technician Tree View -->
        <record id="view_job_technician_tree" model="ir.ui.view">
            <field name="name">job.technician.tree</field>
            <field name="model">job.technician</field>
            <field name="arch" type="xml">
                <list>
                    <field name="name"/>
                    <field name="technician_skills"/>
                    <field name="is_supervisor"/>
                </list>
            </field>
        </record>

        <!-- Technician Form View -->
        <record id="view_job_technician_form" model="ir.ui.view">
            <field name="name">job.technician.form</field>
            <field name="model">job.technician</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <field name="name"/>
                            <field name="is_supervisor"/>
                        </group>
                        <group string="Technician Details">
                            <field name="technician_skills"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Technician Action -->
        <record id="action_job_technician" model="ir.actions.act_window">
            <field name="name">Technicians</field>
            <field name="res_model">job.technician</field>
            <field name="view_mode">list,form</field>
            <field name="help">Manage technicians for job cards</field>
        </record>
    </data>
</odoo>