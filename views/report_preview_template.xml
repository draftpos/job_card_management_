<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_preview_page" name="Report Preview">
        <t t-out="'&lt;!DOCTYPE html&gt;'"/>
        <html>
        <head>
            <meta charset="UTF-8"/>
            <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
            <title><t t-out="title"/></title>
            <style>
                * { margin: 0; padding: 0; box-sizing: border-box; }
                body {
                    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
                    background: #f3f4f6;
                    min-height: 100vh;
                }
                .top-bar {
                    background: #1a1a2e;
                    padding: 15px 30px;
                    display: flex;
                    justify-content: space-between;
                    align-items: center;
                    color: white;
                    position: sticky;
                    top: 0;
                    z-index: 100;
                }
                .top-bar-title { font-weight: 600; font-size: 16px; }
                .top-bar-buttons { display: flex; gap: 10px; }
                .btn {
                    padding: 10px 20px;
                    border-radius: 8px;
                    border: none;
                    cursor: pointer;
                    font-size: 14px;
                    font-weight: 500;
                    transition: all 0.15s;
                    text-decoration: none;
                    display: inline-flex;
                    align-items: center;
                    gap: 6px;
                }
                .btn-back { background: #f59e0b; color: #fff; }
                .btn-back:hover { background: #d97706; }
                .btn-preview { background: #667eea; color: #fff; }
                .btn-preview:hover { background: #5568d3; }
                .btn-download { background: #22b368; color: #fff; }
                .btn-download:hover { background: #1a944f; }
                .pdf-frame {
                    width: 100%;
                    height: calc(100vh - 150px);
                    border: none;
                }
                .loader-overlay {
                    position: fixed;
                    top: 0; left: 0;
                    width: 100%; height: 100%;
                    background: rgba(15, 23, 42, 0.9);
                    display: flex;
                    align-items: center;
                    justify-content: center;
                    z-index: 1000;
                    transition: opacity 0.4s ease;
                }
                .loader-overlay.hidden { opacity: 0; pointer-events: none; }
                .loader-card {
                    background: #fff;
                    padding: 40px 50px;
                    border-radius: 20px;
                    text-align: center;
                }
                .loader-spinner {
                    border: 4px solid #f3f3f3;
                    border-top: 4px solid #667eea;
                    border-radius: 50%;
                    width: 50px;
                    height: 50px;
                    animation: spin 1s linear infinite;
                    margin: 0 auto 15px;
                }
                @keyframes spin {
                    0% { transform: rotate(0deg); }
                    100% { transform: rotate(360deg); }
                }
            </style>
        </head>
        <body>
            <div id="jc-loader" class="loader-overlay">
                <div class="loader-card">
                    <div class="loader-spinner"></div>
                    <p t-out="title"/>
                    <p style="color:#868e96;font-size:13px;margin-top:8px;">Generating document preview...</p>
                </div>
            </div>

            <div id="jc-viewer" style="display:none;">
                <div class="top-bar">
                    <span class="top-bar-title">📄 <t t-out="title"/></span>
                    <div class="top-bar-buttons">
                        <a class="btn btn-back" id="jc-back-btn" t-att-href="back_url">
                            ← Back to Edit
                        </a>
                        <button class="btn btn-preview" type="button" onclick="window.open(pdfUrl, '_blank')">
                            🔍 Open Preview
                        </button>
                        <button class="btn btn-download" type="button" id="jc-download-btn">
                            ⬇ Download PDF
                        </button>
                    </div>
                </div>
                <iframe id="jc-pdf-frame" class="pdf-frame"></iframe>
            </div>

            <script><![CDATA[
                var pdfUrl = '';
                var backUrl = ']]><t t-out="back_url"/><![CDATA[';
                async function loadPDF() {
                    try {
                        var resp = await fetch('/job_card_management/report/preview', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({
                                record_id: ]]><t t-out="record_id"/><![CDATA[,
                                report_name: ']]><t t-out="report_name"/><![CDATA[',
                            }),
                        });
                        if (!resp.ok) throw new Error('Failed');
                        var blob = await resp.blob();
                        pdfUrl = URL.createObjectURL(blob);
                        document.getElementById('jc-loader').classList.add('hidden');
                        setTimeout(function() {
                            document.getElementById('jc-loader').style.display = 'none';
                            document.getElementById('jc-viewer').style.display = 'block';
                            document.getElementById('jc-pdf-frame').src = pdfUrl;
                        }, 500);
                        document.getElementById('jc-download-btn').onclick = function() {
                            var a = document.createElement('a');
                            a.href = pdfUrl;
                            a.download = ']]><t t-out="title"/><![CDATA[.pdf';
                            a.click();
                        };
                        var backBtn = document.getElementById('jc-back-btn');
                        if (backBtn && backUrl) {
                            backBtn.href = backUrl;
                            backBtn.onclick = function(e) {
                                e.preventDefault();
                                window.location.href = backUrl;
                            };
                        }
                    } catch(e) {
                        document.getElementById('jc-loader').innerHTML =
                            '<div class="loader-card"><p style="color:#e5484d;">Failed to generate PDF</p></div>';
                        setTimeout(function() {
                            window.location.href = '/report/pdf/]]><t t-out="report_name"/><![CDATA[/]]><t t-out="record_id"/><![CDATA[';
                        }, 1500);
                    }
                }
                loadPDF();
            ]]></script>
        </body>
        </html>
    </template>
</odoo>
