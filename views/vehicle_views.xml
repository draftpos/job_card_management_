<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================ -->
    <!-- VEHICLE HISTORY REPORT TEMPLATE -->
    <!-- ============================================================ -->
    <template id="vehicle_history_report">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="web.external_layout">
                    <div class="page" style="font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif; font-size: 15px; line-height: 1.7; letter-spacing: 0.4px; color: #333;">
                        
                        <div class="oe_structure"/>
                        
                        <h2 style="color: #1a1a2e; font-size: 24px; font-weight: 700; margin-bottom: 25px;">
                            Vehicle History: <span t-field="doc.name"/>
                        </h2>

                        <div class="row mt-4 mb-4">
                            <div t-if="doc.customer_id" class="col-7">
                                <div style="font-weight: 700; font-size: 16px; color: #1a1a2e; margin-bottom: 6px;">Owner:</div>
                                <div style="font-size: 16px; font-weight: 700; color: #1a1a2e;" t-field="doc.customer_id.name"/>
                            </div>
                            <div class="col-5">
                                <table style="border: none; border-collapse: collapse; width: 100%;">
                                    <tr>
                                        <td style="border: none; padding: 6px 10px; font-weight: 700; color: #1a1a2e; font-size: 14px;">Registration:</td>
                                        <td style="border: none; padding: 6px 10px; font-size: 14px; color: #333; text-align: right;">
                                            <span t-field="doc.registration_number"/>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td style="border: none; padding: 6px 10px; font-weight: 700; color: #1a1a2e; font-size: 14px;">Make:</td>
                                        <td style="border: none; padding: 6px 10px; font-size: 14px; color: #333; text-align: right;">
                                            <span t-field="doc.make"/>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td style="border: none; padding: 6px 10px; font-weight: 700; color: #1a1a2e; font-size: 14px;">Model:</td>
                                        <td style="border: none; padding: 6px 10px; font-size: 14px; color: #333; text-align: right;">
                                            <span t-field="doc.model"/>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td style="border: none; padding: 6px 10px; font-weight: 700; color: #1a1a2e; font-size: 14px;">Year:</td>
                                        <td style="border: none; padding: 6px 10px; font-size: 14px; color: #333; text-align: right;">
                                            <span t-field="doc.year_of_manufacture"/>
                                        </td>
                                    </tr>
                                </table>
                            </div>
                        </div>

                        <!-- Service History -->
                        <div style="margin-top: 30px;">
                            <div style="border-bottom: 2px solid #000; padding-bottom: 8px; margin-bottom: 20px;">
                                <span style="font-size: 16px; font-weight: 700; color: #1a1a2e; text-transform: uppercase;">Service History</span>
                            </div>

                            <t t-foreach="doc.completed_job_cards" t-as="job">
                                <div style="margin-bottom: 30px;">
                                    <div style="font-weight: 700; font-size: 15px; color: #1a1a2e; margin-bottom: 12px;">
                                        Job Card: <span t-field="job.name"/> - <span t-field="job.create_date"/>
                                    </div>
                                    
                                    <table style="border: none; border-collapse: collapse; width: 100%;">
                                        <thead>
                                            <tr style="border-bottom: 2px solid #000;">
                                                <th style="border: none; padding: 12px 10px; font-size: 13px; font-weight: 700; color: #1a1a2e; text-transform: uppercase; text-align: left;">Product</th>
                                                <th style="border: none; padding: 12px 10px; font-size: 13px; font-weight: 700; color: #1a1a2e; text-transform: uppercase; text-align: right;">Quantity</th>
                                                <th style="border: none; padding: 12px 10px; font-size: 13px; font-weight: 700; color: #1a1a2e; text-transform: uppercase; text-align: right;">Unit Price</th>
                                                <th style="border: none; padding: 12px 10px; font-size: 13px; font-weight: 700; color: #1a1a2e; text-transform: uppercase; text-align: right;">Amount</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <t t-foreach="job.job_card_lines" t-as="line">
                                                <t t-if="not line.display_type and line.product_id">
                                                    <tr>
                                                        <td style="border: none; border-bottom: 1px solid #e9ecef; padding: 12px 10px; font-size: 15px; color: #333;">
                                                            <span t-field="line.product_id.name"/>
                                                        </td>
                                                        <td style="border: none; border-bottom: 1px solid #e9ecef; padding: 12px 10px; font-size: 15px; color: #333; text-align: right;">
                                                            <span t-field="line.quantity"/>
                                                            <span> </span>
                                                            <span t-field="line.product_uom_id.name"/>
                                                        </td>
                                                        <td style="border: none; border-bottom: 1px solid #e9ecef; padding: 12px 10px; font-size: 15px; color: #333; text-align: right;">
                                                            $ <span t-esc="'{:.2f}'.format(line.unit_price)"/>
                                                        </td>
                                                        <td style="border: none; border-bottom: 1px solid #e9ecef; padding: 12px 10px; font-size: 15px; font-weight: 700; color: #1a1a2e; text-align: right;">
                                                            $ <span t-esc="'{:.2f}'.format(line.price_total)"/>
                                                        </td>
                                                    </tr>
                                                </t>
                                            </t>
                                        </tbody>
                                    </table>
                                    
                                    <div style="text-align: right; padding: 12px 10px; font-size: 17px; font-weight: 700; color: #1a1a2e; border-top: 2px solid #000; margin-top: 5px;">
                                        Total: $ <span t-esc="'{:.2f}'.format(job.total_amount)"/>
                                    </div>
                                </div>
                            </t>
                            
                            <t t-if="not doc.completed_job_cards">
                                <p style="font-size: 15px; color: #888; font-style: italic; padding: 20px 0;">No completed job cards found for this vehicle.</p>
                            </t>
                        </div>

                    </div>
                </t>
            </t>
        </t>
    </template>

    <!-- ============================================================ -->
    <!-- REPORT ACTION -->
    <!-- ============================================================ -->
    <record id="action_report_vehicle_history" model="ir.actions.report">
        <field name="name">Vehicle History Report</field>
        <field name="model">vehicle</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">job_card_management.vehicle_history_report</field>
        <field name="report_file">job_card_management.vehicle_history_report</field>
        <field name="print_report_name">'Vehicle History - %s' % object.name</field>
    </record>
    
    <!-- ============================================================ -->
    <!-- LIST VIEW -->
    <!-- ============================================================ -->
    <record id="view_vehicle_list" model="ir.ui.view">
        <field name="name">vehicle.list</field>
        <field name="model">vehicle</field>
        <field name="arch" type="xml">
            <list>
                <field name="registration_number"/>
                <field name="make_id"/>
                <field name="model_id"/>
                <field name="name"/>
                <field name="chassis_number"/>
                <field name="year_of_manufacture"/>
                <field name="color" optional="show"/>
                <field name="customer_id"/>
            </list>
        </field>
    </record>

    <!-- ============================================================ -->
    <!-- FORM VIEW -->
    <!-- ============================================================ -->
    <record id="view_vehicle_form" model="ir.ui.view">
        <field name="name">vehicle.form</field>
        <field name="model">vehicle</field>
        <field name="priority">100</field>
        <field name="arch" type="xml">
            <form>
                <header>
                   <button name="action_preview_vehicle_history" string="Print Vehicle History" type="object" class="btn-secondary"/>
                </header>
                <sheet>
                    <group>
                        <group string="Vehicle Identification">
                            <field name="registration_number"/>
                            <field name="make_id" options="{'no_create': False}"/>
                            <field name="model_id" options="{'no_create': False}"/>
                            <field name="year_of_manufacture"/>
                            <field name="color"/>
                            <field name="name" invisible="1"/>
                            <field name="chassis_number"/>
                            <field name="engine_number"/>
                        </group>
                        <group string="Vehicle Specifications">
                            <field name="engine_type_code"/>
                            <field name="transmission"/>
                            <field name="drive_type"/>
                            <field name="fuel_type"/>
                            <field name="odometer_reading"/>
                        </group>
                    </group>
                    <group col="2" string="Service &amp; Customer Details">
                        <group string="Service Specifics">
                            <field name="reason_for_service" nolabel="1" colspan="2"/>
                            <field name="last_service_date"/>
                            <field name="last_service_mileage"/>
                            <field name="known_repairs" nolabel="1" colspan="2"/>
                            <field name="specific_concerns" nolabel="1" colspan="2"/>
                        </group>
                        <group string="Customer Links">
                            <field name="customer_id"/>
                            <field name="insurance_customer_id"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ============================================================ -->
    <!-- ACTION WINDOW -->
    <!-- ============================================================ -->
    <record id="action_vehicle" model="ir.actions.act_window">
        <field name="name">Vehicles</field>
        <field name="res_model">vehicle</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Add your first vehicle
            </p>
        </field>
    </record>

</odoo>