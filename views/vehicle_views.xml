<?xml version="1.0" encoding="utf-8"?>
<odoo>

   <record id="action_report_vehicle_history" model="ir.actions.report">
        <field name="name">Vehicle History Report</field>
        <field name="model">vehicle</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">job_card_management.vehicle_history_report</field>
        <field name="report_file">job_card_management.vehicle_history_report</field>
        <field name="print_report_name">Vehicle History - %(object.name)s</field>
    </record>
    
    <!-- List View -->
    <record id="view_vehicle_list" model="ir.ui.view">
        <field name="name">vehicle.list</field>
        <field name="model">vehicle</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="registration_number"/>
                <field name="chassis_number"/>
                <field name="make"/>
                <field name="model"/>
                <field name="year_of_manufacture"/>
                <field name="customer_id"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_vehicle_form" model="ir.ui.view">
        <field name="name">vehicle.form</field>
        <field name="model">vehicle</field>
        <field name="priority">100</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="job_card_management.action_report_vehicle_history" string="Print Vehicle History" type="action" class="btn-secondary"/>
                </header>
                <sheet>
                    <group>
                        <group string="Vehicle Identification">
                            <field name="name"/>
                            <field name="registration_number"/>
                            <field name="chassis_number"/>
                            <field name="engine_number"/>
                            <field name="make"/>
                            <field name="model"/>
                            <field name="year_of_manufacture"/>
                        </group>
                        <group string="Vehicle Specifications">
                            <field name="engine_type_code"/>
                            <field name="transmission"/>
                            <field name="drive_type"/>
                            <field name="fuel_type"/>
                            <field name="odometer_reading"/>
                        </group>
                    </group>
                    <group col="2" string="Service &amp; Customer Details">
                        <group string="Service Specifics">
                            <field name="reason_for_service" nolabel="1" colspan="2"/>
                            <field name="last_service_date"/>
                            <field name="last_service_mileage"/>
                            <field name="known_repairs" nolabel="1" colspan="2"/>
                            <field name="specific_concerns" nolabel="1" colspan="2"/>
                        </group>
                        <group string="Customer Links">
                            <field name="customer_id"/>
                            <field name="insurance_customer_id"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="action_vehicle" model="ir.actions.act_window">
        <field name="name">Vehicles</field>
        <field name="res_model">vehicle</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Add your first vehicle
            </p>
        </field>
    </record>

    <template id="vehicle_history_report">
    <t t-call="web.html_container">
        <t t-foreach="docs" t-as="doc">
            <t t-call="web.external_layout">
                <div class="page">
                    <div class="oe_structure"/>
                    <div class="row">
                        <div class="col-12">
                            <h1>Vehicle History Report</h1>
                            <h2><span t-field="doc.name"/></h2>
                        </div>
                    </div>
                    <div class="row mt-4">
                        <div class="col-6">
                            <strong>Registration Number:</strong>
                            <span t-field="doc.registration_number"/>
                        </div>
                        <div class="col-6">
                            <strong>Make/Model:</strong>
                            <span t-field="doc.make"/> <span t-field="doc.model"/>
                        </div>
                    </div>
                    <div class="row mt-2">
                        <div class="col-6">
                            <strong>Owner:</strong>
                            <span t-if="doc.customer_id" t-field="doc.customer_id.name"/>
                        </div>
                    </div>
                    <div class="row mt-4" id="history_lines" style="page-break-inside: auto;">
                        <div class="col-12">
                            <h3>Service History</h3>
                            <t t-foreach="doc.completed_job_cards" t-as="job">
                                <div class="mt-3">
                                    <h4>Job Card: <span t-field="job.name"/> - <span t-field="job.create_date"/></h4>
                                    <table class="table table-sm">
                                        <thead>
                                            <tr>
                                                <th class="text-start"><strong>Product</strong></th>
                                                <th class="text-end"><strong>Quantity</strong></th>
                                                <th class="text-end d-none d-sm-table-cell"><strong>Unit Price</strong></th>
                                                <th class="text-end"><strong>Amount</strong></th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <t t-foreach="job.job_card_lines" t-as="line">
                                                <t t-if="line.product_id">
                                                    <tr>
                                                        <td class="text-start"><span t-field="line.product_id.name"/></td>
                                                        <td class="text-end"><span t-field="line.quantity"/> <span t-field="line.product_uom_id.name"/></td>
                                                        <td class="text-end d-none d-sm-table-cell"><span t-field="line.unit_price"/></td>
                                                        <td class="text-end"><span t-field="line.price_total"/></td>
                                                    </tr>
                                                </t>
                                            </t>
                                        </tbody>
                                    </table>
                                    <div class="text-end">
                                        <strong>Total: <span t-field="job.total_amount"/></strong>
                                    </div>
                                </div>
                            </t>
                            <t t-if="not doc.completed_job_cards">
                                <p>No completed job cards found for this vehicle.</p>
                            </t>
                        </div>
                    </div>
                </div>
            </t>
        </t>
    </t>
</template>

</odoo>