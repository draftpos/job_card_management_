<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_job_card_profitability_tree" model="ir.ui.view">
        <field name="name">job.card.profitability.tree</field>
        <field name="model">job.card.profitability</field>
        <field name="arch" type="xml">
            <list string="Job Profitability">
                <field name="job_card_number"/>
                <field name="revenue"/>
                <field name="labor_cost"/>
                <field name="parts_cost"/>
                <field name="expenses_cost"/>
                <field name="total_cost"/>
                <field name="net_profit"/>
                <field name="margin"/>
            </list>
        </field>
    </record>

    <record id="view_job_card_profitability_pivot" model="ir.ui.view">
        <field name="name">job.card.profitability.pivot</field>
        <field name="model">job.card.profitability</field>
        <field name="arch" type="xml">
            <pivot string="Job Profitability">
                <field name="job_card_number" type="row"/>
                <field name="revenue" type="measure"/>
                <field name="labor_cost" type="measure"/>
                <field name="parts_cost" type="measure"/>
                <field name="expenses_cost" type="measure"/>
                <field name="net_profit" type="measure"/>
                <field name="margin" type="measure"/>
            </pivot>
        </field>
    </record>

    <record id="action_job_card_profitability" model="ir.actions.act_window">
        <field name="name">Job Profitability</field>
        <field name="res_model">job.card.profitability</field>
        <field name="view_mode">list,pivot</field>
        <field name="view_ids" eval="[(6, 0, [ref('view_job_card_profitability_tree'), ref('view_job_card_profitability_pivot')])]"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                This report summarizes revenue, labor, parts, and expense costs per job card.
            </p>
        </field>
    </record>

    <menuitem id="menu_job_card_reports" name="Reports" parent="menu_job_card_root" sequence="90"/>
    <menuitem id="menu_job_card_profitability" name="Job Profitability" parent="menu_job_card_reports" sequence="10" action="action_job_card_profitability"/>
</odoo>
