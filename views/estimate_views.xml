<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================ -->
    <!-- QWeb Report Template -->
    <!-- ============================================================ -->
    <template id="estimates_report">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="web.external_layout">
                    <div class="page">
                        <div class="oe_structure"/>
                        <div class="row">
                            <div class="col-12">
                                <h1>Estimate Report</h1>
                                <h2 t-field="doc.name"/>
                            </div>
                        </div>
                        <div class="row mt-4">
                            <div class="col-6">
                                <strong>Customer:</strong>
                                <span t-field="doc.customer_id.name"/>
                            </div>
                            <div class="col-6">
                                <strong>Date:</strong>
                                <span t-if="doc.create_date" t-field="doc.create_date"/>
                            </div>
                        </div>
                        <div class="row mt-2">
                            <div class="col-6">
                                <strong>Vehicle:</strong>
                                <span t-field="doc.vehicle_id.name"/>
                            </div>
                            <div class="col-6">
                                <strong>Vehicle Model:</strong>
                                <span t-field="doc.vehicle_model"/>
                            </div>
                        </div>
                        <div class="row mt-2">
                            <div class="col-6">
                                <strong>Analytic Account:</strong>
                                <span t-if="doc.analytic_account_id" t-field="doc.analytic_account_id.name"/>
                            </div>
                            <div class="col-6">
                                <strong>Vehicle ID:</strong>
                                <span t-field="doc.vehicle_id.registration_number"/>
                            </div>
                        </div>
                        <div class="row mt-2">
                            <div class="col-6">
                                <strong>Estimator:</strong>
                                <span t-field="env.user.name"/>
                            </div>
                        </div>

                        <div class="row mt-4" id="estimate_lines" style="page-break-inside: auto;">
                            <div class="col-12">
                                <h3>Estimate Lines</h3>
                                <div name="sol_table" class="table-responsive">
                                    <table class="table table-sm" id="estimate_table">
                                        <thead style="color: red;">
                                            <tr>
                                                <th class="text-start" id="product_name_header"><strong>Products</strong></th>
                                                <th class="text-end" id="product_qty_header"><strong>Quantity</strong></th>
                                                <th id="product_unit_price_header" class="text-end d-none d-sm-table-cell"><strong>Unit Price</strong></th>
                                                <th class="text-end" id="product_discount_header"><strong>Discount</strong></th>
                                                <th class="text-end" id="subtotal_header"><strong>Subtotal</strong></th>
                                                <th class="text-end" id="amount_header"><strong>Amount</strong></th>
                                            </tr>
                                        </thead>
                                        <tbody class="estimate_tbody">
                                            <t t-foreach="doc.estimate_lines" t-as="line">
                                                <tr t-if="line.display_type == 'line_section'" class="o_line_section" style="color: red;">
                                                    <td colspan="6"><strong t-field="line.name"/></td>
                                                </tr>
                                                <tr t-elif="line.display_type == 'line_note'" class="o_line_note">
                                                    <td colspan="6"><em t-field="line.name"/></td>
                                                </tr>
                                                <tr t-else="" name="tr_product">
                                                    <td name="td_product_name" class="">
                                                        <span name="span_product_name" t-field="line.product_id.name"/>
                                                    </td>
                                                    <td name="td_product_quantity" class="text-end">
                                                        <div>
                                                            <span t-esc="'{:.2f}'.format(line.quantity)"/>
                                                            <span> </span>
                                                            <span t-field="line.product_uom_id.name"/>
                                                        </div>
                                                    </td>
                                                    <td name="td_product_priceunit" class="text-end d-none d-sm-table-cell">
                                                        <div class="text-end">
                                                            <span t-esc="'$ {:.2f}'.format(line.unit_price)"/>
                                                        </div>
                                                    </td>
                                                    <td name="td_product_discount" class="text-end">
                                                        <span t-esc="'{:.2f}'.format(line.discount)"/><t t-if="line.discount">%</t>
                                                    </td>
                                                    <td name="td_product_subtotal" class="text-end">
                                                        <span t-esc="'$ {:.2f}'.format(line.price_subtotal)"/>
                                                    </td>
                                                    <td name="td_product_amount" class="text-end">
                                                        <span t-esc="'$ {:.2f}'.format(line.price_total)"/>
                                                    </td>
                                                </tr>
                                            </t>
                                        </tbody>
                                    </table>
                                </div>

                                <div id="total" name="total" style="page-break-inside: avoid;">
                                    <div class="col-xs-7 col-md-5 ms-auto">
                                        <table class="table table-sm" name="estimate_totals_table">
                                            <tbody>
                                                <t t-if="doc.amount_untaxed">
                                                    <tr class="o_subtotal">
                                                        <td><span>Untaxed Amount</span></td>
                                                        <td class="text-end"><span t-esc="'$ {:.2f}'.format(doc.amount_untaxed)"/></td>
                                                    </tr>
                                                </t>
                                                <t t-if="doc.amount_tax">
                                                    <tr class="o_taxes">
                                                        <td style="max-width: 200px;"><span>Tax Amount</span></td>
                                                        <td class="text-end o_price_total"><span class="text-nowrap"><t t-esc="'$ {:.2f}'.format(doc.amount_tax)"/></span></td>
                                                    </tr>
                                                </t>
                                                <tr class="o_total">
                                                    <td><strong>Total</strong></td>
                                                    <td class="text-end"><strong><span t-esc="'$ {:.2f}'.format(doc.amount_total)"/></strong></td>
                                                </tr>
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </t>
            </t>
        </t>
    </template>

    <!-- ============================================================ -->
    <!-- REPORT ACTION - MUST be defined BEFORE any view that uses it -->
    <!-- ============================================================ -->
    <record id="action_report_estimate" model="ir.actions.report">
        <field name="name">Estimate Report PDF</field>
        <field name="model">estimate</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">job_card_management.estimates_report</field>
        <field name="report_file">job_card_management.estimates_report</field>
        <field name="print_report_name">'Estimate Report - %s' % object.name</field>
    </record>

    <!-- ============================================================ -->
    <!-- ACTION WINDOW -->
    <!-- ============================================================ -->
    <record id="action_estimate" model="ir.actions.act_window">
        <field name="name">Estimates</field>
        <field name="res_model">estimate</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- ============================================================ -->
    <!-- FORM VIEW -->
    <!-- ============================================================ -->
    <record id="view_estimate_form" model="ir.ui.view">
        <field name="name">estimate.form</field>
        <field name="model">estimate</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_submit" string="Submit for Approval" type="object" invisible="state not in ['draft']"/>
                    <button name="action_approve" string="Approve" type="object" invisible="state not in ['submitted']"/>
                    <button name="action_open_job_card" string="Open Job Card" type="object" invisible="state not in ['approved'] or has_job_card"/>
                    <button name="%(job_card_management.action_report_estimate)d" string="Print Estimate" type="action" class="btn-secondary"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                <group col="2">
                    <group col="1" string="Estimate Details">
                        <label for="name" string=""/>
                        <label for="name" string="Estimate"/>
                        <field name="name" nolabel="1"/>
                        <label for="customer_id" string="Customer"/>
                        <field name="customer_id" nolabel="1"/>
                    </group>
                    <group col="1" string="Vehicle Details">
                        <label for="name" string=""/>
                        <label for="vehicle_id" string="Vehicle"/>
                        <field name="vehicle_id" nolabel="1"/>
                        <label for="vehicle_name" string="Vehicle Name"/>
                        <field name="vehicle_name" nolabel="1" readonly="1"/>
                        <label for="vehicle_model" string="Vehicle Model"/>
                        <field name="vehicle_model" nolabel="1" readonly="1"/>
                    </group>
                </group>
                    <notebook>
                        <page string="Order Lines" name="order_lines">
                            <field name="estimate_lines" widget="section_and_note_one2many" nolabel="1">
                                <list editable="bottom" string="Estimate Lines">
                                    <control>
                                        <create name="add_product_control" string="Add a product"/>
                                        <create name="add_section_control" string="Add a section" context="{'default_display_type': 'line_section'}"/>
                                        <create name="add_note_control" string="Add a note" context="{'default_display_type': 'line_note'}"/>
                                    </control>
                                    <field name="display_type" column_invisible="True"/>
                                    <field name="sequence" widget="handle"/>
                                    <field name="product_id" string="Product" required="not display_type" invisible="display_type != False"/>
                                    <field name="name" string="Section/Note" invisible="display_type == False"/>
                                    <field name="quantity" string="Quantity" invisible="display_type != False"/>
                                    <field name="product_uom_id" string="UoM" required="not display_type" invisible="display_type != False" groups="uom.group_uom" width="80px"/>
                                    <field name="unit_price" string="Unit Price" invisible="display_type != False"/>
                                    <field name="tax_ids" string="Taxes" widget="many2many_tags" invisible="display_type != False"/>
                                    <field name="discount" string="Disc.%" width="60px" invisible="display_type != False"/>
                                    <field name="price_subtotal" string="Subtotal" invisible="display_type != False" readonly="1"/>
                                    <field name="price_total" string="Amount" invisible="display_type != False" readonly="1"/>
                                </list>
                            </field>
                        </page>
                        <page string="Other Info" name="other_info">
                            <group>
                                <group string="Customer Signature">
                                </group>
                            </group>
                        </page>
                    </notebook>
                    <table class="float-end">
                        <tbody>
                            <tr>
                                <td class="o_td_label">
                                    <label for="amount_untaxed" class="o_form_label o_tax_total_label">Untaxed Amount</label>
                                </td>
                                <td class="o_list_monetary">
                                    <span class="fw-bold">
                                        <field name="amount_untaxed" widget="monetary" readonly="1"/>
                                    </span>
                                </td>
                            </tr>
                            <tr>
                                <td class="o_td_label">
                                    <label for="amount_total" class="o_form_label o_tax_total_label">Total</label>
                                </td>
                                <td class="o_list_monetary">
                                    <span class="fw-bold" style="font-size: 1.3em;">
                                        <field name="amount_total" widget="monetary" readonly="1"/>
                                    </span>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ============================================================ -->
    <!-- LIST VIEW -->
    <!-- ============================================================ -->
    <record id="view_estimate_list" model="ir.ui.view">
        <field name="name">estimate.list</field>
        <field name="model">estimate</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="customer_id"/>
                <field name="vehicle_name"/>
                <field name="amount_total"/>
                <field name="create_uid"/>
                <field name="state"/>
            </list>
        </field>
    </record>

</odoo>


