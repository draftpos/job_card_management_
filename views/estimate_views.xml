<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="estimates_report">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="web.external_layout">
                    <div class="page" style="font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif; font-size: 15px; line-height: 1.7; letter-spacing: 0.4px; color: #333;">
                        
                        <div class="oe_structure"/>
                        
                        <!-- Title -->
                        <h2 style="color: #1a1a2e; font-size: 24px; font-weight: 700; letter-spacing: 0.6px; margin-bottom: 25px; font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;">
                            <span t-field="doc.name"/>
                        </h2>

                        <!-- Customer & Vehicle Info -->
                        <div class="row mt-4 mb-4">
                            <div t-if="doc.customer_id" class="col-7" style="font-size: 15px;">
                                <div style="font-weight: 700; font-size: 16px; color: #1a1a2e; margin-bottom: 6px; letter-spacing: 0.5px;">Customer Name:</div>
                                <div style="font-size: 16px; font-weight: 700; color: #1a1a2e; letter-spacing: 0.5px;" t-field="doc.customer_id.name"/>
                                <div t-if="doc.customer_id.phone" style="color: #555; margin-top: 4px; font-size: 14px;">
                                    Phone: <span t-field="doc.customer_id.phone"/>
                                </div>
                                <div t-if="doc.customer_id.email" style="color: #555; font-size: 14px;">
                                    Email: <span t-field="doc.customer_id.email"/>
                                </div>
                            </div>
                            <div class="col-5">
                                <table class="table table-sm table-borderless" style="border: none;">
                                    <tr>
                                        <td style="border: none; padding: 6px 10px; font-weight: 700; color: #1a1a2e; font-size: 14px; letter-spacing: 0.4px;">Vehicle:</td>
                                        <td class="text-end" style="border: none; padding: 6px 10px; font-size: 14px; color: #333;">
                                            <span t-field="doc.vehicle_id.name"/>
                                        </td>
                                    </tr>
                                    <tr t-if="doc.vehicle_model">
                                        <td style="border: none; padding: 6px 10px; font-weight: 700; color: #1a1a2e; font-size: 14px; letter-spacing: 0.4px;">Model:</td>
                                        <td class="text-end" style="border: none; padding: 6px 10px; font-size: 14px; color: #333;">
                                            <span t-field="doc.vehicle_model"/>
                                        </td>
                                    </tr>
                                    <tr t-if="doc.vehicle_id.registration_number">
                                        <td style="border: none; padding: 6px 10px; font-weight: 700; color: #1a1a2e; font-size: 14px; letter-spacing: 0.4px;">Vehicle ID:</td>
                                        <td class="text-end" style="border: none; padding: 6px 10px; font-size: 14px; color: #333;">
                                            <span t-field="doc.vehicle_id.registration_number"/>
                                        </td>
                                    </tr>
                                    <tr t-if="doc.create_date">
                                        <td style="border: none; padding: 6px 10px; font-weight: 700; color: #1a1a2e; font-size: 14px; letter-spacing: 0.4px;">Date:</td>
                                        <td class="text-end" style="border: none; padding: 6px 10px; font-size: 14px; color: #333;">
                                            <span t-field="doc.create_date"/>
                                        </td>
                                    </tr>
                                </table>
                            </div>
                        </div>

                        <!-- Lines Table -->
                        <table class="table o_main_table table-borderless mb-0" id="estimate_table" style="border: none; width: 100%;">
                            <thead>
                                <tr style="border-bottom: 3px solid #000 !important;">
                                    <th name="th_description" class="text-start" style="border: none; padding: 16px 14px; font-size: 14px; font-weight: 700; color: #1a1a2e; letter-spacing: 0.6px; text-transform: uppercase;">Description</th>
                                    <th name="th_quantity" class="text-end" style="border: none; padding: 16px 14px; font-size: 14px; font-weight: 700; color: #1a1a2e; letter-spacing: 0.6px; text-transform: uppercase;">Quantity</th>
                                    <th name="th_priceunit" class="text-end" style="border: none; padding: 16px 14px; font-size: 14px; font-weight: 700; color: #1a1a2e; letter-spacing: 0.6px; text-transform: uppercase;">Unit Price</th>
                                    <th name="th_subtotal" class="text-end" style="border: none; padding: 16px 14px; font-size: 14px; font-weight: 700; color: #1a1a2e; letter-spacing: 0.6px; text-transform: uppercase;">Amount</th>
                                </tr>
                            </thead>
                            <tbody class="estimate_tbody">
                                <t t-foreach="doc.estimate_lines" t-as="line">
                                    <tr t-if="line.display_type == 'line_section'" class="o_line_section">
                                        <td colspan="4" style="border: none; background-color: #f2f3f5; padding: 14px 14px; font-weight: 700; font-size: 16px; color: #1a1a2e; letter-spacing: 0.5px;">
                                            <span t-field="line.name"/>
                                        </td>
                                    </tr>
                                    <tr t-elif="line.display_type == 'line_note'" class="o_line_note">
                                        <td colspan="4" style="border: none; padding: 12px 14px; font-style: italic; color: #777; font-size: 14px; letter-spacing: 0.3px;">
                                            <span t-field="line.name"/>
                                        </td>
                                    </tr>
                                    <tr t-else="">
                                        <td style="border: none; border-bottom: 1px solid #e0e0e0; padding: 14px 14px; font-size: 15px; color: #333; letter-spacing: 0.4px;">
                                            <span t-field="line.product_id.name"/>
                                        </td>
                                        <td class="text-end" style="border: none; border-bottom: 1px solid #e0e0e0; padding: 14px 14px; font-size: 15px; color: #333; letter-spacing: 0.4px;">
                                            <span t-esc="'{:.2f}'.format(line.quantity)"/>
                                            <span> </span>
                                            <span t-field="line.product_uom_id.name"/>
                                        </td>
                                        <td class="text-end" style="border: none; border-bottom: 1px solid #e0e0e0; padding: 14px 14px; font-size: 15px; color: #333; letter-spacing: 0.4px;">
                                            $ <span t-esc="'{:.2f}'.format(line.unit_price)"/>
                                        </td>
                                        <td class="text-end o_price_total" style="border: none; border-bottom: 1px solid #e0e0e0; padding: 14px 14px; font-size: 15px; font-weight: 700; color: #1a1a2e; letter-spacing: 0.4px;">
                                            $ <span t-esc="'{:.2f}'.format(line.price_total)"/>
                                        </td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>

                        <!-- Totals -->
                        <div class="row mt-3">
                            <div class="col-7"/>
                            <div class="col-5">
                                <table class="table table-sm table-borderless" style="border: none; border-top: 3px solid #000;">
                                    <tr class="o_subtotal">
                                        <td style="border: none; padding: 10px 12px; font-size: 15px; color: #333; letter-spacing: 0.4px;">Untaxed Amount</td>
                                        <td class="text-end" style="border: none; padding: 10px 12px; font-size: 15px; color: #333;">
                                            $ <span t-esc="'{:.2f}'.format(doc.amount_untaxed)"/>
                                        </td>
                                    </tr>
                                    <tr t-if="doc.amount_tax" class="o_taxes">
                                        <td style="border: none; padding: 10px 12px; font-size: 15px; color: #333; letter-spacing: 0.4px;">Tax Amount</td>
                                        <td class="text-end" style="border: none; padding: 10px 12px; font-size: 15px; color: #333;">
                                            $ <span t-esc="'{:.2f}'.format(doc.amount_tax)"/>
                                        </td>
                                    </tr>
                                    <tr class="o_total">
                                        <td style="border: none; padding: 12px 12px; font-size: 17px; font-weight: 700; color: #1a1a2e; letter-spacing: 0.5px;"><strong>Total</strong></td>
                                        <td class="text-end" style="border: none; padding: 12px 12px; font-size: 17px; font-weight: 700; color: #1a1a2e; letter-spacing: 0.5px;">
                                            <strong>$ <span t-esc="'{:.2f}'.format(doc.amount_total)"/></strong>
                                        </td>
                                    </tr>
                                </table>
                            </div>
                        </div>

                    </div>
                </t>
            </t>
        </t>
    </template>

    <record id="action_report_estimate" model="ir.actions.report">
        <field name="name">Estimate Report</field>
        <field name="model">estimate</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">job_card_management.estimates_report</field>
        <field name="report_file">job_card_management.estimates_report</field>
        <field name="print_report_name">'Estimate - %s' % object.name</field>
    </record>

    <record id="action_estimate" model="ir.actions.act_window">
        <field name="name">Estimates</field>
        <field name="res_model">estimate</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="view_estimate_form" model="ir.ui.view">
        <field name="name">estimate.form</field>
        <field name="model">estimate</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_submit" string="Submit for Approval" type="object" invisible="state not in ['draft']"/>
                    <button name="action_approve" string="Approve" type="object" invisible="state not in ['submitted']"/>
                    <button name="action_open_job_card" string="Open Job Card" type="object" invisible="state not in ['approved'] or has_job_card"/>
                    <button name="action_preview_estimate" string="Print Estimate" type="object" class="btn-secondary"/>
                      <!-- NEW BUTTONS -->
                    <button name="action_send_whatsapp" string="Send WhatsApp" type="object" class="btn-secondary" icon="fa-whatsapp" style="background-color: #25D366; color: white;"/>
                    <button name="action_send_email" string="Email Estimate" type="object" class="btn-secondary" icon="fa-envelope"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <group col="2">
                        <group string="Estimate Details">
                            <field name="name"/>
                            <field name="customer_id"/>
                        </group>
                        <group string="Vehicle Details">
                            <field name="vehicle_id"/>
                            <field name="vehicle_name" readonly="1"/>
                            <field name="vehicle_model" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Order Lines" name="order_lines">
                            <field name="estimate_lines" widget="section_and_note_one2many" nolabel="1">
                                <list editable="bottom" string="Estimate Lines">
                                    <control>
                                        <create name="add_product_control" string="Add a product"/>
                                        <create name="add_section_control" string="Add a section" context="{'default_display_type': 'line_section'}"/>
                                        <create name="add_note_control" string="Add a note" context="{'default_display_type': 'line_note'}"/>
                                    </control>
                                    <field name="display_type" column_invisible="True"/>
                                    <field name="sequence" widget="handle"/>
                                    <field name="product_id" string="Product" required="not display_type" invisible="display_type != False"/>
                                    <field name="name" string="Section/Note" invisible="display_type == False"/>
                                    <field name="quantity" string="Quantity" invisible="display_type != False"/>
                                    <field name="product_uom_id" string="UoM" required="not display_type" invisible="display_type != False" groups="uom.group_uom" width="80px"/>
                                    <field name="unit_price" string="Unit Price" invisible="display_type != False"/>
                                    <field name="tax_ids" string="Taxes" widget="many2many_tags" invisible="display_type != False"/>
                                    <field name="discount" string="Disc.%" width="60px" invisible="display_type != False"/>
                                    <field name="price_subtotal" string="Subtotal" invisible="display_type != False" readonly="1"/>
                                    <field name="price_total" string="Amount" invisible="display_type != False" readonly="1"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                    <table class="float-end">
                        <tbody>
                            <tr>
                                <td class="o_td_label"><label for="amount_untaxed">Untaxed Amount</label></td>
                                <td><field name="amount_untaxed" widget="monetary" readonly="1"/></td>
                            </tr>
                            <tr>
                                <td class="o_td_label"><label for="amount_total">Total</label></td>
                                <td><field name="amount_total" widget="monetary" readonly="1"/></td>
                            </tr>
                        </tbody>
                    </table>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_estimate_list" model="ir.ui.view">
        <field name="name">estimate.list</field>
        <field name="model">estimate</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="customer_id"/>
                <field name="vehicle_name"/>
                <field name="amount_total"/>
                <field name="create_uid"/>
                <field name="state"/>
            </list>
        </field>
    </record>

</odoo>