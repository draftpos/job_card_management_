<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form_job_card" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.job.card</field>
        <field name="model">res.config.settings</field>
        <field name="priority" eval="90"/>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app data-string="Job Card" string="Job Card" name="job_card_management" groups="base.group_system">
                    <block title="General Settings" name="job_card_general_setting_container">
                        <setting string="Default Terms" help="Default terms and conditions for quotations.">
                            <field name="job_card_default_terms" class="w-100"/>
                        </setting>
                    </block>
                    <block title="Quotation Print Format" name="job_card_quotation_print_setting_container">
                        <setting string="Print Full Customer Details" help="If unchecked, only the customer name will be printed.">
                            <field name="print_customer_full_details"/>
                        </setting>
                        <setting string="Show TIN Number" help="Print TIN number on quotations" invisible="not print_customer_full_details">
                            <field name="print_customer_tin"/>
                        </setting>
                        <setting string="Show Phone" help="Print customer phone number on quotations" invisible="not print_customer_full_details">
                            <field name="print_customer_phone"/>
                        </setting>
                        <setting string="Show Email" help="Print customer email on quotations" invisible="not print_customer_full_details">
                            <field name="print_customer_email"/>
                        </setting>
                        <setting string="Show Address" help="Print customer address on quotations" invisible="not print_customer_full_details">
                            <field name="print_customer_address"/>
                        </setting>
                    </block>
                    <block title="Vehicle Required Fields" name="job_card_vehicle_setting_container">
                        <setting string="Require Chassis Number" help="Make chassis number mandatory for vehicles">
                            <field name="vehicle_require_chassis"/>
                        </setting>
                        <setting string="Require Engine Number" help="Make engine number mandatory for vehicles">
                            <field name="vehicle_require_engine"/>
                        </setting>
                        <setting string="Require Year of Manufacture" help="Make year of manufacture mandatory for vehicles">
                            <field name="vehicle_require_year"/>
                        </setting>
                        <setting string="Require Color" help="Make vehicle color mandatory">
                            <field name="vehicle_require_color"/>
                        </setting>
                    </block>

                </app>
            </xpath>
        </field>
    </record>

    <record id="action_job_card_configuration" model="ir.actions.act_window">
        <field name="name">Settings</field>
        <field name="res_model">res.config.settings</field>
        <field name="view_mode">form</field>
        <field name="context">{'module' : 'job_card_management', 'bin_size': False}</field>
    </record>
    
    <menuitem id="menu_job_card_config_settings" name="Settings" parent="menu_job_card_configurations" sequence="0" action="action_job_card_configuration" groups="base.group_system"/>
</odoo>
