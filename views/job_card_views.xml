<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================ -->
    <!-- ============================================================ -->
    <!-- FORM VIEW -->
    <!-- ============================================================ -->
    <record id="view_job_card_form" model="ir.ui.view">
        <field name="name">job.card.form</field>
        <field name="model">job.card</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <!-- Draft state buttons -->
                    <button name="action_approve_job_card" string="Approve Job Card" type="object" invisible="state not in ['draft']"/>
                    
                    <!-- Approved state buttons -->
                    <button name="action_start_job" string="Start Job" type="object" invisible="state not in ['approved']"/>
                    <button name="action_create_requisition" string="Requisition" type="object" invisible="state not in ['in_progress']"/>
                    
                    <!-- In Progress state buttons -->
                    <button name="action_finalize_job_card" string="Finalize Job Card" type="object" invisible="state not in ['in_progress', 'requisition_started']"/>
                    
                    <!-- Completed/Delivered state buttons - REOPEN -->
                    <button name="action_reopen" string="Reopen" type="object" icon="fa-undo" class="btn-warning" invisible="state not in ('completed', 'delivered')" confirm="Are you sure you want to reopen this job card? It will be moved back to draft." groups="job_card_management.group_can_reopen_job_card"/>
                    
                    <!-- Portal Preview button -->
                    <button name="action_preview_portal" string="Preview" type="object" class="btn-secondary"/>
                    
                    <!-- Print Job Card button - uses PDF report like portal -->
                    <button name="action_preview_job_card" string="Print Job Card" type="object" class="btn-secondary"/>
                    
                    <!-- Print Pick Slip button - uses PDF report like portal -->
                    <button name="action_preview_pick_slip" string="Pick Slip" type="object" class="btn-secondary"/>
                    
                    <!-- Statusbar -->
                    <field name="state" widget="statusbar" statusbar_visible="draft,approved,in_progress,requisition_started,completed,delivered"/>
                </header>
                <sheet>
                    <!-- LOCK BADGE when completed/delivered -->
                    <div class="badge rounded-pill text-bg-warning float-end fs-6 border-0" invisible="state not in ('completed', 'delivered')">
                        <i class="fa fa-lock"/> Locked - Click Reopen to edit
                    </div>
                    
                    <group col="3">
                        <group string="Job Card Details">
                            <field name="name" readonly="1"/>
                            <field name="order_number" readonly="state in ('completed', 'delivered')"/>
                            <field name="claims_number" readonly="state in ('completed', 'delivered')"/>
                            <field name="estimate_id" readonly="1"/>
                            <field name="customer_id" readonly="state in ('completed', 'delivered')"/>
                            <field name="vehicle_display" readonly="1"/>
                            <field name="vehicle_reg_number" readonly="1"/>
                            <field name="vehicle_model" readonly="1"/>
                            <field name="start_date" required="1" readonly="state in ('completed', 'delivered')"/>
                            <field name="end_date" required="1" readonly="state in ('completed', 'delivered')"/>
                        </group>
                        <group string="Financial Details">
                            <field name="second_customer_id" readonly="state in ('completed', 'delivered')"/>
                            <field name="excess_percentage" readonly="state in ('completed', 'delivered')"/>
                            <field name="insurance_percentage" readonly="1"/>
                            <field name="analytic_account_id" readonly="state in ('completed', 'delivered')"/>
                        </group>
                        <group string="Team">
                            <field name="technician_ids" widget="many2many_tags" readonly="state in ('completed', 'delivered')"/>
                            <field name="supervisor_ids" widget="many2many_tags" readonly="state in ('completed', 'delivered')"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Order Lines" name="order_lines">
                            <field name="job_card_lines" widget="section_and_note_one2many" nolabel="1" readonly="state in ('completed', 'delivered')">
                                <list editable="bottom" string="Job Card Lines">
                                    <control>
                                        <create name="add_product_control" string="Add a product"/>
                                        <create name="add_section_control" string="Add a section" context="{'default_display_type': 'line_section'}"/>
                                        <create name="add_note_control" string="Add a note" context="{'default_display_type': 'line_note'}"/>
                                    </control>
                                    <field name="line_category" column_invisible="True"/>
                                    <field name="display_type" column_invisible="True"/>
                                    <field name="sequence" widget="handle"/>
                                    <field name="product_id" optional="show" string="Product" required="not display_type" invisible="display_type != False"/>
                                    <field name="name" string="Section / Note" invisible="display_type == False"/>
                                    <field name="quantity" optional="show" string="Quantity" invisible="display_type != False"/>
                                    <field name="product_uom_id" optional="show" string="UoM" invisible="1" required="not display_type" groups="uom.group_uom" width="80px"/>
                                    <field name="unit_price" optional="show" string="Unit Price" invisible="display_type != False"/>
                                    <field name="tax_ids" optional="show" string="Taxes" widget="many2many_tags" invisible="display_type != False"/>
                                    <field name="discount" optional="show" string="Disc.%" width="60px" invisible="display_type != False"/>
                                    <field name="tax_amount" optional="hide" string="Tax" invisible="display_type != False" readonly="1"/>
                                    <field name="price_subtotal" optional="hide" string="Subtotal" invisible="display_type != False" readonly="1"/>
                                    <field name="price_total" optional="show" string="Amount" invisible="display_type != False" readonly="1"/>
                                </list>
                            </field>
                        </page>
                        <page string="Parts" name="parts_lines">
                            <field name="parts_line_ids" widget="section_and_note_one2many" nolabel="1"
                                readonly="state in ('completed', 'delivered')"
                                context="{'default_line_category': 'parts'}">
                                <list editable="bottom">
                                    <control>
                                        <create name="add_product_control" string="Add a product"/>
                                        <create name="add_section_control" string="Add a section" context="{'default_display_type': 'line_section', 'default_line_category': 'parts'}"/>
                                    </control>
                                    <field name="line_category" column_invisible="True"/>
                                    <field name="display_type" column_invisible="True"/>
                                    <field name="sequence" widget="handle"/>
                                    <field name="product_id" optional="show" required="not display_type" invisible="display_type != False"/>
                                    <field name="name" invisible="display_type == False"/>
                                    <field name="quantity" optional="show" invisible="display_type != False"/>
                                    <field name="product_uom_id" optional="show" invisible="display_type != False" groups="uom.group_uom"/>
                                    <field name="unit_price" optional="show" invisible="display_type != False"/>
                                    <field name="tax_ids" optional="show" widget="many2many_tags" invisible="display_type != False"/>
                                    <field name="discount" optional="show" invisible="display_type != False"/>
                                    <field name="tax_amount" optional="hide" string="Tax" invisible="display_type != False" readonly="1"/>
                                    <field name="price_subtotal" optional="hide" readonly="1" invisible="display_type != False"/>
                                    <field name="price_total" optional="show" readonly="1" invisible="display_type != False"/>
                                </list>
                            </field>
                        </page>
                        <page string="Repairs" name="repairs_lines">
                            <field name="repairs_line_ids" widget="section_and_note_one2many" nolabel="1"
                                readonly="state in ('completed', 'delivered')"
                                context="{'default_line_category': 'repairs'}">
                                <list editable="bottom">
                                    <control>
                                        <create name="add_product_control" string="Add a product"/>
                                        <create name="add_section_control" string="Add a section" context="{'default_display_type': 'line_section', 'default_line_category': 'repairs'}"/>
                                    </control>
                                    <field name="line_category" column_invisible="True"/>
                                    <field name="display_type" column_invisible="True"/>
                                    <field name="sequence" widget="handle"/>
                                    <field name="product_id" optional="show" required="not display_type" invisible="display_type != False"/>
                                    <field name="name" invisible="display_type == False"/>
                                    <field name="quantity" optional="show" invisible="display_type != False"/>
                                    <field name="product_uom_id" optional="show" invisible="display_type != False" groups="uom.group_uom"/>
                                    <field name="unit_price" optional="show" invisible="display_type != False"/>
                                    <field name="tax_ids" optional="show" widget="many2many_tags" invisible="display_type != False"/>
                                    <field name="discount" optional="show" invisible="display_type != False"/>
                                    <field name="tax_amount" optional="hide" string="Tax" invisible="display_type != False" readonly="1"/>
                                    <field name="price_subtotal" optional="hide" readonly="1" invisible="display_type != False"/>
                                    <field name="price_total" optional="show" readonly="1" invisible="display_type != False"/>
                                </list>
                            </field>
                        </page>
                        <page string="Paint" name="paint_lines">
                            <field name="paint_line_ids" widget="section_and_note_one2many" nolabel="1"
                                readonly="state in ('completed', 'delivered')"
                                context="{'default_line_category': 'paint'}">
                                <list editable="bottom">
                                    <control>
                                        <create name="add_product_control" string="Add a product"/>
                                        <create name="add_section_control" string="Add a section" context="{'default_display_type': 'line_section', 'default_line_category': 'paint'}"/>
                                    </control>
                                    <field name="line_category" column_invisible="True"/>
                                    <field name="display_type" column_invisible="True"/>
                                    <field name="sequence" widget="handle"/>
                                    <field name="product_id" optional="show" required="not display_type" invisible="display_type != False"/>
                                    <field name="name" invisible="display_type == False"/>
                                    <field name="quantity" optional="show" invisible="display_type != False"/>
                                    <field name="product_uom_id" optional="show" invisible="display_type != False" groups="uom.group_uom"/>
                                    <field name="unit_price" optional="show" invisible="display_type != False"/>
                                    <field name="tax_ids" optional="show" widget="many2many_tags" invisible="display_type != False"/>
                                    <field name="discount" optional="show" invisible="display_type != False"/>
                                    <field name="tax_amount" optional="hide" string="Tax" invisible="display_type != False" readonly="1"/>
                                    <field name="price_subtotal" optional="hide" readonly="1" invisible="display_type != False"/>
                                    <field name="price_total" optional="show" readonly="1" invisible="display_type != False"/>
                                </list>
                            </field>
                        </page>
                        <page string="Fittings" name="fittings_lines">
                            <field name="fittings_line_ids" widget="section_and_note_one2many" nolabel="1"
                                readonly="state in ('completed', 'delivered')"
                                context="{'default_line_category': 'fittings'}">
                                <list editable="bottom">
                                    <control>
                                        <create name="add_product_control" string="Add a product"/>
                                        <create name="add_section_control" string="Add a section" context="{'default_display_type': 'line_section', 'default_line_category': 'fittings'}"/>
                                    </control>
                                    <field name="line_category" column_invisible="True"/>
                                    <field name="display_type" column_invisible="True"/>
                                    <field name="sequence" widget="handle"/>
                                    <field name="product_id" optional="show" required="not display_type" invisible="display_type != False"/>
                                    <field name="name" invisible="display_type == False"/>
                                    <field name="quantity" optional="show" invisible="display_type != False"/>
                                    <field name="product_uom_id" optional="show" invisible="display_type != False" groups="uom.group_uom"/>
                                    <field name="unit_price" optional="show" invisible="display_type != False"/>
                                    <field name="tax_ids" optional="show" widget="many2many_tags" invisible="display_type != False"/>
                                    <field name="discount" optional="show" invisible="display_type != False"/>
                                    <field name="tax_amount" optional="hide" string="Tax" invisible="display_type != False" readonly="1"/>
                                    <field name="price_subtotal" optional="hide" readonly="1" invisible="display_type != False"/>
                                    <field name="price_total" optional="show" readonly="1" invisible="display_type != False"/>
                                </list>
                            </field>
                        </page>
                        <page string="Labour" name="labour_lines">
                            <field name="labour_line_ids" widget="section_and_note_one2many" nolabel="1"
                                readonly="state in ('completed', 'delivered')"
                                context="{'default_line_category': 'labour'}">
                                <list editable="bottom">
                                    <control>
                                        <create name="add_product_control" string="Add a product"/>
                                        <create name="add_section_control" string="Add a section" context="{'default_display_type': 'line_section', 'default_line_category': 'labour'}"/>
                                    </control>
                                    <field name="line_category" column_invisible="True"/>
                                    <field name="display_type" column_invisible="True"/>
                                    <field name="sequence" widget="handle"/>
                                    <field name="product_id" optional="show" required="not display_type" invisible="display_type != False"/>
                                    <field name="name" invisible="display_type == False"/>
                                    <field name="quantity" optional="show" invisible="display_type != False"/>
                                    <field name="product_uom_id" optional="show" invisible="display_type != False" groups="uom.group_uom"/>
                                    <field name="unit_price" optional="show" invisible="display_type != False"/>
                                    <field name="tax_ids" optional="show" widget="many2many_tags" invisible="display_type != False"/>
                                    <field name="discount" optional="show" invisible="display_type != False"/>
                                    <field name="tax_amount" optional="hide" string="Tax" invisible="display_type != False" readonly="1"/>
                                    <field name="price_subtotal" optional="hide" readonly="1" invisible="display_type != False"/>
                                    <field name="price_total" optional="show" readonly="1" invisible="display_type != False"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                    <group class="oe_subtotal_footer oe_right" colspan="2" name="job_card_total">
                        <field name="amount_untaxed" widget="monetary" string="Total Excl"/>
                        <field name="amount_tax" widget="monetary" string="Total Tax"/>
                        <div class="oe_subtotal_footer_separator oe_inline o_td_label">
                            <label for="amount_total" string="Total Incl"/>
                        </div>
                        <field name="amount_total" nolabel="1" class="oe_subtotal_footer_separator" widget="monetary"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ============================================================ -->
    <!-- LIST VIEW -->
    <!-- ============================================================ -->
    <record id="view_job_card_list" model="ir.ui.view">
        <field name="name">job.card.list</field>
        <field name="model">job.card</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="customer_id"/>
                <field name="vehicle_id"/>
                <field name="total_amount"/>
                <field name="create_uid"/>
                <field name="state" widget="badge" decoration-muted="state == 'draft'" decoration-info="state == 'approved'" decoration-warning="state == 'in_progress'" decoration-success="state == 'completed' or state == 'delivered'"/>
            </list>
        </field>
    </record>

    <!-- ============================================================ -->
    <!-- ACTION WINDOW -->
    <!-- ============================================================ -->
    <record id="action_job_card" model="ir.actions.act_window">
        <field name="name">Job Cards</field>
        <field name="res_model">job.card</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>