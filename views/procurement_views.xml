<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_procurement_form" model="ir.ui.view">
        <field name="name">procurement.form</field>
        <field name="model">procurement</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_submit_for_approval" string="Submit for Requisition Approval" type="object" invisible="state not in ['draft']"/>
                    <button name="action_approve_requisition" string="Requisition Approved" type="object" invisible="state not in ['submitted_for_approval']"/>
                    <button name="action_create_purchase_order" string="Create Purchase Order" type="object" invisible="state not in ['approved']"/>
                    <button name="action_create_grv" string="Create GRV" type="object" invisible="state not in ['purchase_order_created']"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_purchase_orders" type="object" class="oe_stat_button" icon="fa-shopping-cart">
                            <field name="purchase_order_created_count" widget="statinfo" string="PO Created"/>
                        </button>
                        <button name="action_view_internal_transfers" type="object" class="oe_stat_button" icon="fa-truck">
                            <field name="internal_transfer_created_count" widget="statinfo" string="Transfers"/>
                        </button>
                        <button name="action_view_delivered_items" type="object" class="oe_stat_button" icon="fa-check-circle">
                            <field name="receipt_delivered_count" widget="statinfo" string="Delivered"/>
                        </button>
                    </div>
                    <field name="name" invisible="1"/>
                    <field name="job_card_id" invisible="1"/>
                    <group col="2">
                        <group>
                        </group>
                        <group>
                            <field name="analytic_account_id" string="Analytic Line" readonly="1"/>
                        </group>
                    </group>
                    <separator string="Procurement Lines"/>
                    <field name="procurement_lines" widget="section_and_note_one2many" nolabel="1">
                        <list editable="bottom">
                            <control>
                                <create name="add_product_control" string="Add a product"/>
                                <create name="add_section_control" string="Add a section" context="{'default_display_type': 'line_section'}"/>
                                <create name="add_note_control" string="Add a note" context="{'default_display_type': 'line_note'}"/>
                            </control>
                            <field name="display_type" column_invisible="True"/>
                            <field name="sequence" widget="handle"/>
                            <field name="product_id" optional="show" string="Product" required="not display_type" invisible="display_type != False"/>
                            <field name="name" string="Section/Note" invisible="display_type == False"/>
                            <field name="product_uom_id" optional="show" string="UoM" invisible="1" required="not display_type" groups="uom.group_uom" width="80px"/>
                            <field name="quantity" optional="show" string="Quantity" invisible="display_type != False"/>
                            <field name="buying_price" required="not display_type and type == 'purchase_order'" invisible="display_type != False or type == 'internal_transfer'"/>
                            <field name="selling_price" invisible="display_type != False or type == 'internal_transfer'"/>
                            <field name="profit" readonly="1" invisible="display_type != False or type == 'internal_transfer'"/>
                            <field name="markup_percent" readonly="1" invisible="display_type != False or type == 'internal_transfer'"/>
                            <field name="type"/>
                            <field name="vendor_id" invisible="type == 'internal_transfer'" required="type == 'purchase_order'" context="{'default_is_supplier': True}"/>
                            <field name="receipt_status"/>
                            <field name="purchase_order_created"/>
                            <field name="internal_transfer_created"/>
                        </list>
                    </field>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_procurement_list" model="ir.ui.view">
        <field name="name">procurement.list</field>
        <field name="model">procurement</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="job_card_id"/>
                <field name="analytic_account_id"/>
                <field name="total_amount"/>
                <field name="create_uid"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="action_procurement" model="ir.actions.act_window">
        <field name="name">Procurement</field>
        <field name="res_model">procurement</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="view_procurement_zero_price_wizard" model="ir.ui.view">
        <field name="name">procurement.zero.price.wizard.form</field>
        <field name="model">procurement.zero.price.wizard</field>
        <field name="arch" type="xml">
            <form string="Warning">
                <p>Are you sure you want to set the buying price to zero for one or more products?</p>
                <footer>
                    <button string="Yes, Proceed" name="action_confirm" type="object" class="btn-primary"/>
                    <button string="No, Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>